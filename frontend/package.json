{
  "name": "polymarket-walerike-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "check:accountledger": "node --experimental-strip-types tests/accountLedgerFormat.test.ts",
    "check:copyoverviewstate": "node --experimental-strip-types tests/copyOverviewState.test.ts",
    "check:view-types": "tsc --noEmit --pretty false --strict --target ES2020 --module ESNext --moduleResolution Bundler --skipLibCheck tests/viewTypes.test.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@radix-ui/react-slot": "latest",
    "@vitejs/plugin-react": "latest",
    "class-variance-authority": "latest",
    "clsx": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "tailwind-merge": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "latest",
    "postcss": "latest",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "latest"
  }
}
